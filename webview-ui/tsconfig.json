{
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../src/webview-contract.ts", "../src/webview-model-cost.ts"]
}
