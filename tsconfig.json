{
	"compilerOptions": {
		"module": "ES2022",
		"moduleResolution": "bundler",
		"types": [
			"node",
			"bun"
		],
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"],
			"@shared/*": ["./src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["webview-ui"]
}
