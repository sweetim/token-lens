{
  "name": "token-lens",
  "displayName": "Token Lens",
  "description": "Track LLM token usage and costs in the status bar with detailed analytics in the sidebar",
  "version": "1.3.0",
  "license": "MIT",
  "icon": "icons/logo.png",
  "galleryBanner": {
    "color": "#1A0533",
    "theme": "dark"
  },
  "keywords": [
    "token",
    "usage",
    "llm",
    "ai",
    "cost",
    "analytics",
    "monitor",
    "dashboard",
    "tokenlens"
  ],
  "homepage": "https://github.com/sweetim/token-lens#readme",
  "bugs": {
    "url": "https://github.com/sweetim/token-lens/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sweetim/token-lens.git"
  },
  "publisher": "timx",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "token-lens",
          "title": "TokenLens",
          "icon": "icons/token-stack-lens.svg"
        }
      ]
    },
    "views": {
      "token-lens": [
        {
          "type": "webview",
          "id": "token-lens.tokenSidebar",
          "name": "Token Analytics"
        }
      ]
    },
    "commands": [
      {
        "command": "token-lens.refresh",
        "title": "TokenLens: Refresh"
      },
      {
        "command": "token-lens.setApiKey",
        "title": "TokenLens: Set API Key"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run copy-wasm",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:webview:tsc": "tsc --noEmit --watch --project webview-ui/tsconfig.json",
    "copy-wasm": "node -e \"require('fs').copyFileSync('node_modules/sql.js/dist/sql-wasm.wasm','dist/sql-wasm.wasm')\"",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run copy-wasm",
    "check-types": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project webview-ui/tsconfig.json",
    "lint": "eslint src webview-ui/src"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
