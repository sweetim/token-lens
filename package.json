{
  "name": "token-lens",
  "displayName": "TokenLens",
  "description": "Visualize LLM provider token usage in the status bar",
  "version": "0.0.1",
  "license": "MIT",
  "icon": "icons/logo.png",
  "galleryBanner": {
    "color": "#1A0533",
    "theme": "dark"
  },
  "keywords": [
    "token",
    "usage",
    "llm",
    "ai",
    "cost",
    "analytics",
    "monitor",
    "dashboard"
  ],
  "homepage": "https://github.com/sweetim/token-usage-info#readme",
  "bugs": {
    "url": "https://github.com/sweetim/token-usage-info/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sweetim/token-usage-info.git"
  },
  "publisher": "timx",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "token-lens",
          "title": "TokenLens",
          "icon": "icons/zai.svg"
        }
      ]
    },
    "views": {
      "token-lens": [
        {
          "type": "webview",
          "id": "token-lens.tokenSidebar",
          "name": "Token Usage by Project"
        }
      ]
    },
    "commands": [
      {
        "command": "token-lens.refresh",
        "title": "TokenLens: Refresh"
      },
      {
        "command": "token-lens.setApiKey",
        "title": "TokenLens: Set API Key"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
